<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><rect width="200" height="200" fill="#f0fff4" rx="20"/><circle cx="100" cy="90" r="55" fill="#48BB78"><animate attributeName="r" values="55;60;55" dur="1.5s" repeatCount="indefinite"/></circle><polyline points="70,90 90,110 130,70" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" fill="none"/><text x="100" y="175" font-family="Arial" font-size="13" font-weight="bold" fill="#48BB78" text-anchor="middle">Đặt hàng thành công!</text></svg>