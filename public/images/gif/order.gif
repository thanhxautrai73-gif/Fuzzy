<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><rect width="200" height="200" fill="#f0fff4" rx="20"/><rect x="50" y="40" width="100" height="130" fill="#48BB78" rx="10" opacity="0.9"><animate attributeName="opacity" values="0.9;0.7;0.9" dur="2s" repeatCount="indefinite"/></rect><line x1="70" y1="80" x2="130" y2="80" stroke="white" stroke-width="3"/><line x1="70" y1="100" x2="130" y2="100" stroke="white" stroke-width="3"/><line x1="70" y1="120" x2="110" y2="120" stroke="white" stroke-width="3"/><text x="100" y="195" font-family="Arial" font-size="11" fill="#888" text-anchor="middle">Chưa có đơn hàng</text></svg>